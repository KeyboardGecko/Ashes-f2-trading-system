		cancelButton = new("TradeUIButton");
		cancelButton.Init(0, 0, int(20 * UIScale), int(10 * UIScale));
		cancelButton.SetDefaultIcon("tradeoff");
		cancelButton.SetAction('cancel_trade');
	
		invUpButton = new("TradeUIButton");
		invUpButton.Init(0, 0, SLOT_SIZE / 2, SLOT_SIZE / 4);
		invUpButton.SetDefaultIcon("arrowup");

		invDownButton = new("TradeUIButton");
		invDownButton.Init(0, 0, SLOT_SIZE / 2, SLOT_SIZE / 4);
		invDownButton.SetDefaultIcon("arrowdn");

		sellUpButton = new("TradeUIButton");
		sellUpButton.Init(0, 0, SLOT_SIZE / 2, SLOT_SIZE / 4);
		sellUpButton.SetDefaultIcon("arrowup");

		sellDownButton = new("TradeUIButton");
		sellDownButton.Init(0, 0, SLOT_SIZE / 2, SLOT_SIZE / 4);
		sellDownButton.SetDefaultIcon("arrowdn");

		buyUpButton = new("TradeUIButton");
		buyUpButton.Init(0, 0, SLOT_SIZE / 2, SLOT_SIZE / 4);
		buyUpButton.SetDefaultIcon("arrowup");

		buyDownButton = new("TradeUIButton");
		buyDownButton.Init(0, 0, SLOT_SIZE / 2, SLOT_SIZE / 4);
		buyDownButton.SetDefaultIcon("arrowdn");

		traderUpButton = new("TradeUIButton");
		traderUpButton.Init(0, 0, SLOT_SIZE / 2, SLOT_SIZE / 4);
		traderUpButton.SetDefaultIcon("arrowup");

		traderDownButton = new("TradeUIButton");
