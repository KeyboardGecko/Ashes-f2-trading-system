	clearscope String GetItemDescriptionByClass(Name cls) const
	{
		for (int i = 0; i < tradeWhitelist.Size(); i++)
		{
			if (tradeWhitelist[i].cls == cls)
			{
				if (tradeWhitelist[i].description != "")
					return tradeWhitelist[i].description;

				if (tradeWhitelist[i].displayName != "")
					return tradeWhitelist[i].displayName;

				return "" .. cls;
			}
		}

		return "" .. cls;
	}

	ui String GetHoveredDescriptionFromColumn(TradeItemColumn col)
	{
		if (col == null)
			return "";

		int hovered = col.GetHoveredIndex(cursor.x, cursor.y);
		if (hovered == -1)
			return "";

		let entry = col.GetEntry(hovered);
		if (entry == null)
			return "";

		return GetItemDescriptionByClass(entry.cls);
	}

	ui String GetFirstHoveredDescription()
	{
		String txt = GetHoveredDescriptionFromColumn(inventoryColumn);
		if (txt != "") return txt;

		txt = GetHoveredDescriptionFromColumn(sellColumn);
		if (txt != "") return txt;

		txt = GetHoveredDescriptionFromColumn(buyColumn);
		if (txt != "") return txt;

		txt = GetHoveredDescriptionFromColumn(traderColumn);
		if (txt != "") return txt;

		return "";
	}

	ui String GetHoveredItemLabel()
	{
		if (infoMessage != "")
			return infoMessage;

		if (qtyDialog.visible)
			return "";

		return GetFirstHoveredDescription();
	}

	ui void DrawHoveredItemLabel()
	{
		String label = GetHoveredItemLabel();
		if (label == "")
			return;

		int textX = inventoryColumn.x;
		int textY = inventoryColumn.y - 50;

		Screen.DrawText(
			SmallFont,
			Font.CR_WHITE,
			textX,
			textY,
			label,
			DTA_ScaleX, 2,
			DTA_ScaleY, 2
		);
	}


	clearscope static TradeUIOverlay Get()
	{
		return TradeUIOverlay(StaticEventHandler.Find('TradeUIOverlay'));
	}

	void SetVisible(bool on)
	{
		visible = on;
		IsUiProcessor = on;
		RequireMouse = on;
		cursor.SetVisible(on);

		if (!on)
		{
			selectedItemIndex = -1;
			draggingItem = false;
			selectedItemClass = '';
			dragSourceColumn = COL_NONE;
			lmbHeld = false;
			cursor.ClearIcon();

			qtyDialog.Close();
			ClearPendingTransfer();
		}
	}

	void UpdateScreenLayout()
	{
		SCREEN_W = Screen.GetWidth();
		SCREEN_H = Screen.GetHeight();

		cursor.SetScreenSize(SCREEN_W, SCREEN_H);

		int gap = int(10 * UIScale);
		int groupGap = int(30 * UIScale);
		int totalW = COLUMN_WIDTH * 4 + gap * 2 + groupGap;
		int startX = (SCREEN_W - totalW) / 2;
		int topY = int(40 * UIScale);

		inventoryColumn.x = startX;
		inventoryColumn.y = topY;

		sellColumn.x = inventoryColumn.x + COLUMN_WIDTH + gap;
		sellColumn.y = topY;

		buyColumn.x = sellColumn.x + COLUMN_WIDTH + groupGap;
		buyColumn.y = topY;

		traderColumn.x = buyColumn.x + COLUMN_WIDTH + gap;
		traderColumn.y = topY;

		LayoutButtons();
	}

	void LayoutButtons()
	{
		int listHeight = (MAX_VISIBLE - 1) * SLOT_STEP + SLOT_SIZE;
		int btnH = SLOT_SIZE / 2;
		int btnW = SLOT_SIZE / 4;

		int midX = sellColumn.x + COLUMN_WIDTH + (buyColumn.x - (sellColumn.x + COLUMN_WIDTH)) / 2;
		int tradeW = int(20 * UIScale);
		int tradeH = int(10 * UIScale);
	
		tradeButton.SetPos(midX - tradeW / 2, sellColumn.y + SLOT_STEP * 2);
		tradeButton.SetSize(tradeW, tradeH);

		cancelButton.SetPos(midX - tradeW / 2, tradeButton.y + tradeH + int(4 * UIScale));
		cancelButton.SetSize(tradeW, tradeH);

		invUpButton.SetPos(inventoryColumn.x + COLUMN_WIDTH + 2, inventoryColumn.y + listHeight - btnH - btnH/2);
		invUpButton.SetSize(btnW, btnH / 2);

		invDownButton.SetPos(inventoryColumn.x + COLUMN_WIDTH + 2, inventoryColumn.y + listHeight - btnH);
		invDownButton.SetSize(btnW, btnH / 2);

		sellUpButton.SetPos(sellColumn.x + COLUMN_WIDTH + 2, sellColumn.y + listHeight - btnH - btnH/2);
		sellUpButton.SetSize(btnW, btnH / 2);

		sellDownButton.SetPos(sellColumn.x + COLUMN_WIDTH + 2, sellColumn.y + listHeight - btnH);
		sellDownButton.SetSize(btnW, btnH / 2);

		buyUpButton.SetPos(buyColumn.x + COLUMN_WIDTH + 2, buyColumn.y + listHeight - btnH - btnH/2);
		buyUpButton.SetSize(btnW, btnH / 2);

		buyDownButton.SetPos(buyColumn.x + COLUMN_WIDTH + 2, buyColumn.y + listHeight - btnH);
		buyDownButton.SetSize(btnW, btnH / 2);

		traderUpButton.SetPos(traderColumn.x + COLUMN_WIDTH + 2, traderColumn.y + listHeight - btnH - btnH/2);
		traderUpButton.SetSize(btnW, btnH / 2);

		traderDownButton.SetPos(traderColumn.x + COLUMN_WIDTH + 2, traderColumn.y + listHeight - btnH);
		traderDownButton.SetSize(btnW, btnH / 2);
	}

	void CollectInventoryEntries(Actor owner, out Array<TradeUIItemEntry> outEntries)
	{
		outEntries.Clear();

		for (let item = owner.Inv; item != null; item = item.Inv)
		{
			Name cls = item.GetClassName();
			TradeItemDef def = FindTradeItemDef(cls);

			if (def == null)
				continue;

			int found = -1;

			for (int i = 0; i < outEntries.Size(); i++)
			{
				if (outEntries[i].cls == cls)
				{
					found = i;
					break;
				}
			}

			if (found == -1)
			{
			
				TradeUIItemEntry entry = TradeTextUtil.MakeTradeEntry(cls, item.Amount, def.price, def.icon);
				outEntries.Push(entry);
			}
			else
			{
				outEntries[found].count += item.Amount;
			}
		}
	}

	void RebuildPlayerColumns(Actor owner)
	{
		Array<TradeUIItemEntry> baseEntries;
		Array<TradeUIItemEntry> visibleEntries;

		CollectInventoryEntries(owner, baseEntries);

		for (int i = 0; i < baseEntries.Size(); i++)
		{
			let base = baseEntries[i];
			if (base == null)
				continue;

			int reserved = 0;

			int sellIdx = sellColumn.FindEntryIndexByClass(base.cls);
			if (sellIdx != -1)
			{
				let sellEntry = sellColumn.GetEntry(sellIdx);
				if (sellEntry != null)
					reserved = sellEntry.count;
			}

			int remaining = base.count - reserved;
			if (remaining <= 0)
				continue;

			TradeUIItemEntry entry = TradeTextUtil.MakeTradeEntry(
				base.cls,
				remaining,
				base.price,
				base.icon
			);
			visibleEntries.Push(entry);
		}

		inventoryColumn.SetEntries(visibleEntries);

		int maxScroll = visibleEntries.Size() - MAX_VISIBLE;
		if (maxScroll < 0)
			maxScroll = 0;

		if (inventoryColumn.scroll > maxScroll)
			inventoryColumn.scroll = maxScroll;
	}

	void RebuildTraderColumn()
	{
		Array<TradeUIItemEntry> visibleEntries;

		for (int i = 0; i < traderStock.Size(); i++)
		{
			let base = traderStock[i];
			if (base == null)
				continue;

			int reserved = 0;

			int buyIdx = buyColumn.FindEntryIndexByClass(base.cls);
			if (buyIdx != -1)
			{
				let buyEntry = buyColumn.GetEntry(buyIdx);
				if (buyEntry != null)
					reserved = buyEntry.count;
			}

			int remaining = base.count - reserved;
			if (remaining <= 0)
				continue;

			TradeUIItemEntry entry = TradeTextUtil.MakeTradeEntry(
				base.cls,
				remaining,
				base.price,
				base.icon
			);
			visibleEntries.Push(entry);
		}

		traderColumn.SetEntries(visibleEntries);

		int maxScroll = visibleEntries.Size() - MAX_VISIBLE;
		if (maxScroll < 0)
			maxScroll = 0;

		if (traderColumn.scroll > maxScroll)
			traderColumn.scroll = maxScroll;
	}

	void SetTraderStock(Array<TradeUIItemEntry> stock)
	{
		traderStock.Clear();

		for (int i = 0; i < stock.Size(); i++)
		{
			traderStock.Push(stock[i]);
		}

		RebuildTraderColumn();
	}
	
	int GetHoveredColumnId(int mx, int my)
	{
		if (inventoryColumn.IsInside(mx, my)) return COL_INV;
		if (sellColumn.IsInside(mx, my)) return COL_SELL;
		if (buyColumn.IsInside(mx, my)) return COL_BUY;
		if (traderColumn.IsInside(mx, my)) return COL_TRADER;
		return COL_NONE;
	}

	ui int GetDropTargetForSourceUI(int sourceCol)
	// for ui context
	{
		if (sourceCol == COL_INV) return COL_SELL;
		if (sourceCol == COL_SELL) return COL_INV;
		if (sourceCol == COL_TRADER) return COL_BUY;
		if (sourceCol == COL_BUY) return COL_TRADER;
		return COL_NONE;
	}

	int GetDropTargetForSource(int sourceCol)
	// for play context
	{
		if (sourceCol == COL_INV) return COL_SELL;
		if (sourceCol == COL_SELL) return COL_INV;
		if (sourceCol == COL_TRADER) return COL_BUY;
		if (sourceCol == COL_BUY) return COL_TRADER;
		return COL_NONE;
	}

	TradeItemColumn GetColumnById(int id)
	{
		switch (id)
		{
			case COL_INV: return inventoryColumn;
			case COL_SELL: return sellColumn;
			case COL_BUY: return buyColumn;
			case COL_TRADER: return traderColumn;
		}
		return null;
	}

	bool TryStartDragFromColumn(TradeItemColumn col, int colId, int vx, int vy)
	{
		if (col == null)
			return false;

		int index = col.GetHoveredIndex(vx, vy);
		if (index == -1)
			return false;

		let entry = col.GetEntry(index);
		if (entry == null)
			return false;

		draggingItem = true;
		dragSourceColumn = colId;
		selectedItemIndex = index;
		selectedItemClass = entry.cls;

		TextureID icon = entry.icon;
		if (!icon.isValid())
			icon = TexMan.CheckForTexture("ITMDEF", TexMan.TYPE_Any);

		cursor.SetIcon(icon);
		cursor.SetPos(vx, vy);
		return true;
	}

//// TRADING LOGIC ////
	bool RemoveItemFromActorInventory(Actor owner, Name cls, int amount)
	{
		if (!owner || amount <= 0)
			return false;

		for (let item = owner.Inv; item != null; item = item.Inv)
		{
			if (item.GetClassName() == cls)
			{
				if (item.Amount > amount)
				{
					item.Amount -= amount;
					return true;
				}

				item.Amount = 0;
				item.Destroy();
				return true;
			}
		}

		return false;
	}

	void GiveItemToActorInventory(Actor owner, Name cls, int amount)
	{
		if (!owner || amount <= 0)
			return;

		owner.A_GiveInventory("" .. cls, amount);
	}

	void AddOrMergeTraderStock(TradeUIItemEntry item)
	{
		for (int i = 0; i < traderStock.Size(); i++)
		{
			if (traderStock[i].cls == item.cls)
			{
				traderStock[i].count += item.count;
				return;
			}
		}

		TradeItemDef def = FindTradeItemDef(item.cls);
		if (def == null)
			return;

		TradeUIItemEntry entry = TradeTextUtil.MakeTradeEntry(item.cls, item.count, def.price, def.icon);
		traderStock.Push(entry);
	}

	void RemoveTraderStockAmount(Name cls, int amount)
	{
		for (int i = 0; i < traderStock.Size(); i++)
		{
			if (traderStock[i].cls == cls)
			{
				traderStock[i].count -= amount;
				if (traderStock[i].count <= 0)
					traderStock.Delete(i);
				return;
			}
		}
	}

	void PerformTrade()
	{
		if (sellColumn.entries.Size() == 0 && buyColumn.entries.Size() == 0)
		{
			infoMessage = "";
			return;
		}
		
		int sellTotal = sellColumn.GetTotalPrice();
		int buyTotal = buyColumn.GetTotalPrice();
			
		if (buyTotal > sellTotal)
		{
			infoMessage = TradeTextUtil.NoMessages();
			return;
		}

		let p = players[consoleplayer];
		if (!p || !p.mo)
			return;

		for (int i = 0; i < sellColumn.entries.Size(); i++)
		{
			let entry = sellColumn.entries[i];
			if (entry == null)
				continue;

			RemoveItemFromActorInventory(p.mo, entry.cls, entry.count);
			AddOrMergeTraderStock(entry);
		}

		for (int i = 0; i < buyColumn.entries.Size(); i++)
		{
			let entry = buyColumn.entries[i];
			if (entry == null)
				continue;

			GiveItemToActorInventory(p.mo, entry.cls, entry.count);
			RemoveTraderStockAmount(entry.cls, entry.count);
		}
		
		sellColumn.Clear();
		buyColumn.Clear();

		RebuildPlayerColumns(p.mo);
		RebuildTraderColumn();

		let nstate = TraderStateHandler.Get();
		if (nstate != null && currentTraderKey != "")
		{
			nstate.SetLiveTraderStock(currentTraderKey, traderStock);
		}

		infoMessage = TradeTextUtil.YesMessages();
	}
	
	void CancelTrade()
	{
		if (sellColumn.entries.Size() == 0 && buyColumn.entries.Size() == 0)
		{
			infoMessage = "";
			return;
		}
	
		selectedItemIndex = -1;
		draggingItem = false;
		selectedItemClass = '';
		dragSourceColumn = COL_NONE;
		lmbHeld = false;

		sellColumn.Clear();
		buyColumn.Clear();
		cursor.ClearIcon();

		let p = players[consoleplayer];
		if (p && p.mo)
		{
			RebuildPlayerColumns(p.mo);
		}

		RebuildTraderColumn();

		infoMessage = "Trade cancelled.";
	}
///////////////////////

	bool TryScrollButton(TradeUIButton button, TradeItemColumn col, bool up)
	{
		if (!ProcessButtonClick(button))
			return false;

		if (up) col.ScrollUp();
		else col.ScrollDown();
		return true;
	}

	bool ProcessButtons()
	{
		if (qtyDialog.visible)
			return ProcessQuantityDialogButtons();

		if (TryScrollButton(invUpButton, inventoryColumn, true)) return true;
		if (TryScrollButton(invDownButton, inventoryColumn, false)) return true;
		if (TryScrollButton(sellUpButton, sellColumn, true)) return true;
		if (TryScrollButton(sellDownButton, sellColumn, false)) return true;
		if (TryScrollButton(buyUpButton, buyColumn, true)) return true;
		if (TryScrollButton(buyDownButton, buyColumn, false)) return true;
		if (TryScrollButton(traderUpButton, traderColumn, true)) return true;
		if (TryScrollButton(traderDownButton, traderColumn, false)) return true;
		if (ProcessButtonClick(tradeButton) || ProcessButtonClick(cancelButton))
			return true;

		return false;
	}

	override void WorldTick()
	{
		let p = players[consoleplayer];
		if (!p || !p.mo)
			return;

	}

	bool ScrollHoveredColumn(int mx, int my, bool up)
	{
		if (inventoryColumn.IsInside(mx, my))
		{
			if (up) inventoryColumn.ScrollUp(); else inventoryColumn.ScrollDown();
			return true;
		}
		if (sellColumn.IsInside(mx, my))
		{
			if (up) sellColumn.ScrollUp(); else sellColumn.ScrollDown();
			return true;
		}
		if (buyColumn.IsInside(mx, my))
		{
			if (up) buyColumn.ScrollUp(); else buyColumn.ScrollDown();
			return true;
		}
		if (traderColumn.IsInside(mx, my))
		{
			if (up) traderColumn.ScrollUp(); else traderColumn.ScrollDown();
			return true;
		}
		return false;
	}

	override void NetworkProcess(ConsoleEvent e)
	{
		if (e.Name == "tradeui_toggle")
		{
			SetVisible(!visible);
			return;
		}
			
		if (e.Name == "do_trade")
		{
			PerformTrade();
			return;
		}
				
		if (e.Name == "open_tradeui_id")
		{
			let reg = TraderRegistry.Get();
			if (reg != null)
			{
				String key = reg.FindKeyByNetId(e.Args[0]);
				if (key != "")
				{
// 					Console.Printf("Opening trader by id: %d -> %s", e.Args[0], key);
					OpenForTraderKey(key);
				}
				else
				{
					Console.Printf("No trader for id %d", e.Args[0]);
				}
			}
			return;
		}
			
		if (e.Name == "open_tradeui_for")
		{
			let p = players[consoleplayer];
			if (p != null && p.ConversationNPC != null)
			{
// 				Console.printf("Trader:, %s", p.ConversationNPC);
				OpenForTraderActor(p.ConversationNPC);
			}
			else
			{
				infoMessage = "No trader.";
			}
			return;
		}
		
		if (e.Name == "cancel_trade")
		{
			CancelTrade();
			return;
		}	
		
		if (e.Name == "scrollup_toggle" || e.Name == "mwheel_up")
		{
			ScrollHoveredColumn(e.Args[0], e.Args[1], true);
			return;
		}

		if (e.Name == "scrolldown_toggle" || e.Name == "mwheel_down")
		{
			ScrollHoveredColumn(e.Args[0], e.Args[1], false);
			return;
		}

		if (e.Name == "lmb_up")
		{
			int vx = e.Args[0];
			int vy = e.Args[1];

			if (qtyDialog.visible)
			{
				cursor.SetPos(vx, vy);

				if (lmbHeld)
				{
					lmbHeld = false;
					ProcessQuantityDialogButtons();
				}
				return;
			}

			if (draggingItem)
			{
				int hoveredCol = GetHoveredColumnId(vx, vy);
				int targetCol = GetDropTargetForSource(dragSourceColumn);

				if (hoveredCol == targetCol)
				{
					let src = GetColumnById(dragSourceColumn);
					let dst = GetColumnById(targetCol);

					if (src != null && dst != null)
					{
						let entry = src.GetEntry(selectedItemIndex);

						if (entry != null)
						{
							if (entry.count > 1)
							{
								int sourceCol = dragSourceColumn;
								int destCol = targetCol;

								selectedItemIndex = -1;
								draggingItem = false;
								dragSourceColumn = COL_NONE;
								selectedItemClass = '';
								cursor.ClearIcon();

								OpenQuantityDialog(entry, sourceCol, destCol);
								return;
							}

							pendingSourceColumn = dragSourceColumn;
							pendingTargetColumn = targetCol;
							pendingItemClass = entry.cls;
							pendingItemPrice = entry.price;
							ExecuteTransferAmount(1);
							return;
						}					}
				}
			}

			selectedItemIndex = -1;
			draggingItem = false;
			dragSourceColumn = COL_NONE;
			selectedItemClass = '';
			cursor.ClearIcon();

			if (lmbHeld)
			{
				lmbHeld = false;
				if (ProcessButtons())
					return;
			}

			return;
		}

		if (e.Name == "lmb_down")
		{
			lmbHeld = true;

			int vx = e.Args[0];
			int vy = e.Args[1];

			if (TryStartDragFromColumn(inventoryColumn, COL_INV, vx, vy)) return;
			if (TryStartDragFromColumn(sellColumn, COL_SELL, vx, vy)) return;
			if (TryStartDragFromColumn(buyColumn, COL_BUY, vx, vy)) return;
			if (TryStartDragFromColumn(traderColumn, COL_TRADER, vx, vy)) return;

			return;
		}
		
		if (e.Name == "qty_plus")
		{
			qtyDialog.AddOne();
			return;
		}

		if (e.Name == "qty_minus")
		{
			qtyDialog.RemoveOne();
			return;
		}

		if (e.Name == "qty_all")
		{
			qtyDialog.SetAll();
			return;
		}

		if (e.Name == "qty_ok")
		{
			ExecuteTransferAmount(qtyDialog.quantity);
			return;
		}

		if (e.Name == "qty_cancel")
		{
			CancelQuantityDialog();
			return;
		}
		
		if (e.Name == "qty_digit")
		{
			qtyDialog.AppendDigit(e.Args[0]);
			return;
		}

		if (e.Name == "qty_backspace")
		{
			qtyDialog.BackspaceDigit();
			return;
		}
	}

	bool ProcessButtonClick(TradeUIButton button)
	{
		if (button == null)
			return false;

		if (button.IsInside(cursor.x, cursor.y))
		{
			button.Activate(self);
			return true;
		}

		return false;
	}

	override bool UiProcess(UiEvent e)
	{
		if (!visible)
			return false;

		if (qtyDialog.visible)
		{
			if (e.Type == UiEvent.Type_MouseMove)
			{
				cursor.SetPos(e.MouseX, e.MouseY);
				return true;
			}

			if (e.Type == UiEvent.Type_LButtonDown)
			{
				SendNetworkEvent("lmb_down", cursor.x, cursor.y);
				return true;
			}

			if (e.Type == UiEvent.Type_LButtonUp)
			{
				SendNetworkEvent("lmb_up", cursor.x, cursor.y);
				return true;
			}

			if (e.Type == UiEvent.Type_WheelUp)
			{
				SendNetworkEvent("qty_plus");
				return true;
			}

			if (e.Type == UiEvent.Type_WheelDown)
			{
				SendNetworkEvent("qty_minus");
				return true;
			}

			if (e.Type == UiEvent.Type_KeyDown)
			{
				if (e.KeyChar >= 48 && e.KeyChar <= 57) // 0..9
				{
					SendNetworkEvent("qty_digit", e.KeyChar - 48);
					return true;
				}

				if (e.KeyChar == 8) // Backspace
				{
					SendNetworkEvent("qty_backspace");
					return true;
				}

				if (e.KeyChar == 13) // Enter
				{
					SendNetworkEvent("qty_ok");
					return true;
				}

				if (e.KeyChar == 27) // ESC
				{
					SendNetworkEvent("qty_cancel");
					return true;
				}
			}

			return true;
		}
		
		if (e.Type == UiEvent.Type_MouseMove)
		{
			cursor.SetPos(e.MouseX, e.MouseY);
			return true;
		}

		if (e.Type == UiEvent.Type_LButtonDown)
		{
			SendNetworkEvent("lmb_down", cursor.x, cursor.y);
			return true;
		}

		if (e.Type == UiEvent.Type_LButtonUp)
		{
			SendNetworkEvent("lmb_up", cursor.x, cursor.y);
			return true;
		}

		if (e.Type == UiEvent.Type_WheelUp)
		{
			SendNetworkEvent("mwheel_up", cursor.x, cursor.y);
			return true;
		}

		if (e.Type == UiEvent.Type_WheelDown)
		{
			SendNetworkEvent("mwheel_down", cursor.x, cursor.y);
			return true;
		}

		if (e.Type == UiEvent.Type_KeyDown)
		{
			if (e.KeyChar == 67 || e.KeyChar == 99 || e.KeyChar == 27)
			{
				SendNetworkEvent("tradeui_toggle");
				return true;
			}

			if (e.KeyChar == 87 || e.KeyChar == 119)
			{
				SendNetworkEvent("scrollup_toggle", cursor.x, cursor.y);
				return true;
			}

			if (e.KeyChar == 83 || e.KeyChar == 115)
			{
				SendNetworkEvent("scrolldown_toggle", cursor.x, cursor.y);
				return true;
			}
		}

		return true;
	}
	
	ui void DrawDecorativeTexture(TextureID tex, double x, double y)
	{
		Screen.DrawTexture(tex, false, x, y,
			DTA_VirtualWidth, UI_VW,
			DTA_VirtualHeight, UI_VH,
			DTA_Alpha, 0.5,
			DTA_KeepRatio, true,
			DTA_TopLeft, true
		);
	}
	
	ui void DrawColumnName(int x, int y, String colname)
	{
		int offsetX = 8;
		int offsetY = -20;
		
		Screen.DrawText(
			SmallFont,
			Font.CR_WHITE,
			x + offsetX,
			y + offsetY,
			colname,
			DTA_ScaleX, 2,
			DTA_ScaleY, 2
		);
	}
		
	ui void DrawBackgroundPanel()
	{
		TextureID bg = TexMan.CheckForTexture("BGPANEL", TexMan.TYPE_Any);
		if (bg.isValid())
		{
			Vector2 sz = TexMan.GetScaledSize(bg);

			double panelX = (UI_VW - sz.x) * 0.5;
			double panelY = (UI_VH - sz.y) * 0.3;

			DrawDecorativeTexture(bg, panelX, panelY);
		}
	}

	ui void DrawButton(TradeUIButton btn)
	{
		bool hov = false;
		bool pressed = false;

		if (!qtyDialog.visible)
		{
			hov = btn.IsInside(cursor.x, cursor.y);
			pressed = hov && lmbHeld;
		}

		btn.Draw(hov, pressed);
	}

	override void RenderOverlay(RenderEvent e)
	{
		if (!visible)
			return;

		DrawBackgroundPanel();
		
		int invSelected = -1;
		int sellSelected = -1;
		int buySelected = -1;
		int traderSelected = -1;

		if (draggingItem)
		{
			if (dragSourceColumn == COL_INV)
				invSelected = selectedItemIndex;
			else if (dragSourceColumn == COL_SELL)
				sellSelected = selectedItemIndex;
			else if (dragSourceColumn == COL_BUY)
				buySelected = selectedItemIndex;
			else if (dragSourceColumn == COL_TRADER)
				traderSelected = selectedItemIndex;
		}

		int hoveredInv = -1;
		int hoveredSell = -1;
		int hoveredBuy = -1;
		int hoveredTrader = -1;

		if (!qtyDialog.visible)
		{
			hoveredInv = inventoryColumn.GetHoveredIndex(cursor.x, cursor.y);
			hoveredSell = sellColumn.GetHoveredIndex(cursor.x, cursor.y);
			hoveredBuy = buyColumn.GetHoveredIndex(cursor.x, cursor.y);
			hoveredTrader = traderColumn.GetHoveredIndex(cursor.x, cursor.y);
		}

		int dropTarget = COL_NONE;

		if (!qtyDialog.visible && draggingItem)
			dropTarget = GetDropTargetForSourceUI(dragSourceColumn);

		inventoryColumn.SetHighlighted(!qtyDialog.visible && dropTarget == COL_INV && inventoryColumn.IsInside(cursor.x, cursor.y));
		sellColumn.SetHighlighted(!qtyDialog.visible && dropTarget == COL_SELL && sellColumn.IsInside(cursor.x, cursor.y));
		buyColumn.SetHighlighted(!qtyDialog.visible && dropTarget == COL_BUY && buyColumn.IsInside(cursor.x, cursor.y));
		traderColumn.SetHighlighted(!qtyDialog.visible && dropTarget == COL_TRADER && traderColumn.IsInside(cursor.x, cursor.y));

		inventoryColumn.Draw(hoveredInv, invSelected);
		sellColumn.Draw(hoveredSell, sellSelected);
		buyColumn.Draw(hoveredBuy, buySelected);
		traderColumn.Draw(hoveredTrader, traderSelected);

		DrawHoveredItemLabel();
		DrawColumnName(inventoryColumn.x, inventoryColumn.y, "INV");
		DrawColumnName(sellColumn.x, sellColumn.y, "SELL");
		DrawColumnName(buyColumn.x, buyColumn.y, "BUY");
		DrawColumnName(traderColumn.x, traderColumn.y, "TRADER");

		DrawButton(invUpButton);
		DrawButton(invDownButton);
		DrawButton(sellUpButton);
		DrawButton(sellDownButton);
		DrawButton(buyUpButton);
		DrawButton(buyDownButton);
		DrawButton(traderUpButton);
		DrawButton(traderDownButton);
		DrawButton(tradeButton);
		DrawButton(cancelButton);

		if (qtyDialog.visible)
		{
			qtyDialog.Draw(cursor.x, cursor.y, lmbHeld);
		}
		
		cursor.Draw();
	}
}